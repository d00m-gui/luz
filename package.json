{
  "name": "luz",
  "version": "0.1.0",
  "description": "Luz is a lightweight library designed to simplify theming and styling in modern web applications.",
  "keywords": [
    "astro",
    "color-palette",
    "css",
    "css-in-ts",
    "css-variables",
    "custom-properties",
    "design-tokens",
    "oklch",
    "react",
    "styling",
    "tailwind-alternative",
    "theming"
  ],
  "homepage": "https://github.com/d00m-gui/luz#readme",
  "bugs": {
    "url": "https://github.com/d00m-gui/luz/issues"
  },
  "license": "MIT",
  "author": "d00m-gui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d00m-gui/luz.git"
  },
  "workspaces": [
    "examples/*"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.js"
      }
    },
    "./astro": {
      "import": {
        "types": "./dist/astro/index.d.ts",
        "default": "./dist/astro/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "bunup": "bunup",
    "dev:watch": "bunup --watch",
    "dev": "bun run --cwd examples/ui dev",
    "astro:dev": "bun run --cwd examples/nimda dev",
    "format": "oxfmt",
    "lint": "oxlint --ignore-pattern \"dist/**\" .",
    "prepare": "bun simple-git-hooks",
    "prepublishOnly": "bun run lint && bun run type-check && bun run test && bun run bunup",
    "release": "bumpp --commit --push --tag",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:watch": "bun test --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "lightningcss": "^1.32.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "astro": "^7.0.6",
    "bumpp": "^11.1.0",
    "bunup": "^0.16.32",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "simple-git-hooks": "^2.13.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "astro": "^6.0.5",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "typescript": ">=4.5.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "astro": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "simple-git-hooks": {
    "pre-commit": "bun run lint && bun run type-check"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=18"
  }
}
