{
	"name": "luz",
	"version": "0.1.0",
	"description": "Luz is a lightweight library designed to simplify theming and styling in modern web applications.",
	"homepage": "https://github.com/d00m-gui/luzCSS",
	"bugs": {
		"url": "https://github.com/d00m-gui/luzCSS/issues"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/d00m-gui/luzCSS.git"
	},
	"workspaces": [
		"test/**"
	],
	"files": [
		"dist"
	],
	"type": "module",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		},
		"./react": {
			"import": {
				"types": "./dist/react/index.d.ts",
				"default": "./dist/react/index.js"
			}
		},
		"./bun": {
			"import": {
				"types": "./dist/bun/index.d.ts",
				"default": "./dist/bun/index.js"
			}
		},
		"./astro": {
			"import": {
				"types": "./dist/astro/index.d.ts",
				"default": "./dist/astro/index.js"
			}
		},
		"./style/sheet": {
			"import": {
				"types": "./dist/style/sheet.d.ts",
				"default": "./dist/style/sheet.js"
			}
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"bunup": "bunup",
		"dev:watch": "bunup --watch",
		"dev": "bun run --cwd test/ui dev",
		"astro:dev": "bun run --cwd test/nimda dev",
		"format": "oxfmt",
		"lint": "oxlint",
		"prepare": "bun simple-git-hooks",
		"release": "bumpp --commit --push --tag",
		"test": "bun test",
		"test:coverage": "bun test --coverage",
		"test:watch": "bun test --watch",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@base-ui/react": "^1.2.0"
	},
	"devDependencies": {
		"@types/bun": "^1.3.9",
		"@types/react": "^19.2.14",
		"bumpp": "^10.4.1",
		"bunup": "^0.16.29",
		"oxfmt": "^0.35.0",
		"oxlint": "^1.50.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"astro": "^6.0.5",
		"simple-git-hooks": "^2.13.1",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0",
		"react-dom": "^18.0.0 || ^19.0.0",
		"astro": "^6.0.5",
		"typescript": ">=4.5.0"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		},
		"react-dom": {
			"optional": true
		},
		"astro": {
			"optional": true
		},
		"typescript": {
			"optional": true
		}
	},
	"simple-git-hooks": {
		"pre-commit": "bun run lint && bun run type-check"
	}
}